{
  "name": "@rodkisten/fabrica",
  "version": "0.1.0",
  "description": "A tiny typed HTML and CSS runtime foundation for TypeScript.",
  "type": "module",
  "license": "MIT",
  "author": "Rod Kisten",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodkisten/fabrica.git"
  },
  "homepage": "https://fabrica.rodkisten.com",
  "bugs": {
    "url": "https://github.com/rodkisten/fabrica/issues"
  },
  "keywords": [
    "typescript",
    "html",
    "css",
    "tagged-template",
    "runtime",
    "nextra"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('coverage',{recursive:true,force:true});\"",
    "coverage": "vitest run --coverage",
    "dev": "tsdown --watch",
    "docs:build": "pnpm docs:generate && next build docs",
    "docs:dev": "pnpm docs:generate && next dev docs",
    "docs:generate": "tsx scripts/generate-docs.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "release": "changeset publish",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.39.1",
    "@nextra/components": "^4.2.17",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.14",
    "eslint": "^9.39.1",
    "happy-dom": "^20.0.11",
    "next": "^16.0.7",
    "nextra": "^4.2.17",
    "nextra-theme-docs": "^4.2.17",
    "prettier": "^3.7.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsdown": "^0.16.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.1"
}
